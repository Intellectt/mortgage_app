[app]

# Application title
title = Mortgage App

# Package name
package.name = mortgageapp

# Package domain
package.domain = org.test

# Source code location
source.dir = .

# Files to include
source.include_exts = py,png,jpg,kv,atlas

# Version
version = 0.1

# Requirements
requirements = python3,kivy,kivymd

# Orientation
orientation = portrait

# Fullscreen
fullscreen = 0

# Android API
android.api = 31

# Minimum API
android.minapi = 21

# Android SDK
android.sdk = 24

# Android NDK
android.ndk = 23b

# Architecture
android.archs = armeabi-v7a

# Permissions
android.permissions = INTERNET

# Presplash color
android.presplash_color = #FFFFFF

# Enable AndroidX
android.enable_androidx = True

# Log level
log_level = 2

# Warning level
warn_on_root = 1


[buildozer]

# Directory for build output
bin_dir = ./bin